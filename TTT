function switchChatTab(tab) {
    S.chatTab = tab;
    document.querySelectorAll('.chat-tab').forEach(t => t.classList.remove('active'));
    document.getElementById('tab' + tab.charAt(0).toUpperCase() + tab.slice(1)).classList.add('active');
    debouncedRenderChats();
}

function debouncedRenderChats() {
    clearTimeout(S.renderTimer);
    S.renderTimer = setTimeout(renderChatsList, 120);
}

function getGroupUnreadCount(gid) {
    const readKey = `groupRead_${gid}_${S.user.uid}`;
    const lastRead = parseInt(localStorage.getItem(readKey) || '0');
    const msgs = S.groupMessages[gid] || {};
    return Object.values(msgs).filter(m => m.from !== S.user.uid && (m.time || 0) > lastRead).length;
}

function renderChatsList() {
    const list = document.getElementById('chatsList');
    const filterQ = document.getElementById('chatListSearch').value.trim().toLowerCase();
    let arr = [];
    let groupCount = 0, unreadCount = 0;

    Object.entries(S.groups).forEach(([gid, g]) => {
        if(g.members && g.members.includes(S.user.uid)) {
            groupCount++;
            const ml = Object.values(S.messages[gid] || {});
            const lm = ml.length ? ml.sort((a,b)=>a.time-b.time)[ml.length-1] : null;
            const unread = getGroupUnreadCount(gid);
            if(unread > 0) unreadCount++;
            arr.push({ id: gid, type: 'group', data: g, lastMsg: lm, time: lm ? lm.time : (g.createdAt||0), unread, pinned: !!(S.groupPins && S.groupPins[gid]) });
        }
    });

    const peers = new Set();
    Object.keys(S.messages).forEach(cid => {
        const pt = cid.split('_');
        if(pt.length === 2) {
            if(pt[0] === S.user.uid) peers.add(pt[1]);
            else if(pt[1] === S.user.uid) peers.add(pt[0]);
        }
    });
    Object.keys(S.contacts).forEach(uid => peers.add(uid));

    peers.forEach(uid => {
        const u = S.users[uid]; if(!u) return;
        const cd = S.contacts[uid];
        const cid = getChatId(S.user.uid, uid);
        const ml = Object.values(S.messages[cid] || {}).sort((a,b) => a.time - b.time);
        const lm = ml.length ? ml[ml.length-1] : null;
        const unread = ml.filter(m => m.from !== S.user.uid && !m.read).length;
        if(unread > 0) unreadCount++;
        arr.push({ id: uid, type: 'private', user: u, cd, lastMsg: lm, time: lm ? lm.time : 0, unread, pinned: cd?.pinned || false });
    });

    arr.sort((a, b) => {
        if(a.pinned && !b.pinned) return -1;
        if(!a.pinned && b.pinned) return 1;
        return b.time - a.time;
    });

    document.getElementById('badgeAll').textContent = arr.length;
    document.getElementById('badgeGroups').textContent = groupCount;
    document.getElementById('badgeUnread').textContent = unreadCount;

    if(S.chatTab === 'groups') arr = arr.filter(c => c.type === 'group');
    if(S.chatTab === 'unread') arr = arr.filter(c => c.unread > 0);
    if(filterQ) {
        arr = arr.filter(c => {
            const n = c.type === 'group' ? c.data.name : c.user.nickname;
            return n.toLowerCase().includes(filterQ);
        });
    }

    if(!arr.length) {
        list.innerHTML = `<div style="text-align:center; padding:30px 20px; color:var(--text-muted); font-size:13px;">${filterQ ? 'Ничего не найдено' : 'Нет чатов'}</div>`;
        return;
    }

    list.innerHTML = arr.map(c => {
        let name, avatarHtml, lastText, online = false;

        if(c.type === 'group') {
            name = (c.pinned ? '📌 ' : '') + escapeHtml(c.data.name);
            avatarHtml = c.data.avatar ? `<img src="${c.data.avatar}" alt="">` : '👥';
            const sender = c.lastMsg ? (c.lastMsg.system ? '' : (c.lastMsg.from === S.user.uid ? 'Вы: ' : (S.users[c.lastMsg.from]?.nickname?.split(' ')[0] || '') + ': ')) : '';
            lastText = c.lastMsg ? escapeHtml(sender + (c.lastMsg.text || '📷 Фото')) : '—';
        } else {
            name = (c.pinned ? '📌 ' : '') + escapeHtml(c.user.nickname);
            avatarHtml = c.user.avatar ? `<img src="${c.user.avatar}" alt="">` : escapeHtml((c.user.nickname||'?')[0].toUpperCase());
            online = c.user.online;
            lastText = c.lastMsg ? escapeHtml((c.lastMsg.from === S.user.uid ? 'Вы: ' : '') + (c.lastMsg.text || '📷 Фото')) : '—';
        }

        const timeStr = c.time ? formatTime(c.time) : '';
        const active = S.activeChat === c.id ? 'active' : '';
        const onCls = online ? 'is-online' : '';

        return `
        <div class="chat-item ${active} ${onCls}" data-id="${c.id}" data-type="${c.type}" oncontextmenu="chatItemCtxMenu(event,'${c.id}','${c.type}')">
            <div class="ci-actions">
                <button style="background:var(--warning)" onclick="togglePin('${c.id}',event,'${c.type}')" title="Закрепить">📌</button>
                <button style="background:var(--danger)" onclick="deleteChatHistory('${c.id}','${c.type}',event)" title="Удалить">🗑</button>
            </div>
            <div class="ci-avatar">${avatarHtml}<div class="status-dot"></div></div>
            <div class="ci-info">
                <div class="ci-row1">
                    <div class="ci-name">${name}</div>
                    <div class="ci-time">${timeStr}</div>
                </div>
                <div class="ci-row2">
                    <div class="ci-last">${lastText}</div>
                    ${c.unread > 0 ? `<span class="ci-unread">${c.unread > 99 ? '99+' : c.unread}</span>` : ''}
                </div>
            </div>
        </div>`;
    }).join('');

    list.querySelectorAll('.chat-item').forEach(el => {
        el.querySelector('.ci-info')?.addEventListener('click', () => openChat(el.dataset.id, el.dataset.type));
        el.querySelector('.ci-avatar')?.addEventListener('click', () => openChat(el.dataset.id, el.dataset.type));
    });

    list.querySelectorAll('.chat-item').forEach(el => {
        let sx = 0;
        el.addEventListener('touchstart', e => { sx = e.touches[0].clientX; }, { passive: true });
        el.addEventListener('touchend', e => {
            const dx = sx - e.changedTouches[0].clientX;
            if(dx > 55) el.classList.add('swiped');
            else if(dx < -20) el.classList.remove('swiped');
        });
    });
}

function chatItemCtxMenu(e, id, type) {
    showCtxMenu(e, [
        { icon:'💬', label:'Открыть чат', action: () => openChat(id, type) },
        { icon:'📌', label: (type==='group' ? (S.groupPins&&S.groupPins[id]) : S.contacts[id]?.pinned) ? 'Открепить' : 'Закрепить', action: () => togglePin(id, null, type) },
        'divider',
        { icon:'🗑', label:'Очистить историю', danger: true, action: () => deleteChatHistory(id, type) },
    ]);
}

