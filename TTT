async function createGroupChat() {
    const name = document.getElementById('groupNameInput').value.trim();
    const desc = document.getElementById('groupDescInput').value.trim();
    if(!name) return showToast("Введите название группы");
    const checked = Array.from(document.querySelectorAll('#groupMembersList input:checked')).map(cb => cb.value);
    if(!checked.length) return showToast("Выберите хотя бы одного участника");
    const members = [S.user.uid, ...checked];
    const gid = db.ref('groups').push().key;
    await db.ref('groups/' + gid).set({
        name, description: desc, members, createdBy: S.user.uid,
        createdAt: firebase.database.ServerValue.TIMESTAMP, avatar: '', muted: {}
    });
    document.getElementById('groupNameInput').value = '';
    document.getElementById('groupDescInput').value = '';
    hideModals();
    openChat(gid, 'group');
    showToast("Группа создана 🎉");
}

async function leaveGroup() {
    if(!await customConfirm("Выход из группы", "Вы покинете группу. Вернуться можно только по приглашению.")) return;
    const g = S.groups[S.activeChat];
    const newMembers = (g.members || []).filter(m => m !== S.user.uid);
    if(newMembers.length === 0) {
        await db.ref('groups/' + S.activeChat).remove();
        await db.ref('groupMessages/' + S.activeChat).remove();
    } else {
        await db.ref('groups/' + S.activeChat + '/members').set(newMembers);
    }
    hideModals(); closeChat();
    showToast("Вы покинули группу");
}

async function kickMember(uid) {
    if(!await customConfirm("Выгнать", `Выгнать ${S.users[uid]?.nickname || uid} из группы?`)) return;
    const g = S.groups[S.activeChat];
    const newMembers = (g.members || []).filter(m => m !== uid);
    await db.ref('groups/' + S.activeChat + '/members').set(newMembers);
    await groupSystemMsg(S.activeChat, `${myName()} выгнал(-а) ${nameOf(uid)}`);
    showToast("Участник выгнан");
