}

// =====================================================
// SEND MESSAGE
// =====================================================
async function sendMessage() {
    const inp = document.getElementById('messageInput');
    const text = inp.value.trim();
    if(!text && !S.pendingImage) return;
    if(!S.activeChat) return;

    if(S.activeChatType === 'private') {
        const u = S.users[S.activeChat];
        if(!u) return;
        if(S.contacts[S.activeChat]?.blocked) return showToast("Вы заблокировали этого пользователя.");
        // (#10) they blocked me
        if(S.allContacts?.[S.activeChat]?.[S.user.uid]?.blocked) return showToast("Пользователь заблокировал вас.");
        // (#11) if the restricted user already wrote to me, the chat is unlocked
        const cid = getChatId(S.user.uid, S.activeChat);
        const theyWroteFirst = Object.values(S.messages[cid] || {}).some(m => m.from === S.activeChat);
        if(!theyWroteFirst) {
            if(u.msgVis === 'nobody') return showToast("Пользователь запретил сообщения.");
            if(u.msgVis === 'contacts') {
                const snap = await db.ref(`contacts/${S.activeChat}/${S.user.uid}`).once('value');
                if(!snap.exists() || snap.val()?.blocked) return showToast("Писать может только контакт.");
            }
        }
    } else {
        const g = S.groups[S.activeChat];
        if(g?.muted?.[S.user.uid] && g.muted[S.user.uid] > Date.now()) {
            return showToast("🔇 У вас мут в этой группе.");
        }
    }

    const msg = { from: S.user.uid, time: firebase.database.ServerValue.TIMESTAMP, read: false };
    if(text) msg.text = text;
    if(S.pendingImage) { msg.image = S.pendingImage; cancelImage(); }
    if(S.pendingQuote) { msg.quote = S.pendingQuote; cancelQuote(); }

    const path = S.activeChatType === 'private'
        ? `messages/${getChatId(S.user.uid, S.activeChat)}`
        : `groupMessages/${S.activeChat}`;

    inp.value = '';
    inp.style.height = 'auto';
    await db.ref(path).push(msg);
    inp.focus();
}

function handleInputKey(e) {
    if(e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
}

function handleImageSelect(e) {
    const f = e.target.files[0]; if(!f) return;
    if(f.size > 5 * 1024 * 1024) return showToast("Файл больше 5 МБ");
    const r = new FileReader();
    r.onload = ev => {
        S.pendingImage = ev.target.result;
        document.getElementById('imgPreviewThumb').src = ev.target.result;
        document.getElementById('imgPreviewWrap').classList.add('open');
    };
    r.readAsDataURL(f);
    e.target.value = '';
}

function cancelImage() {
    S.pendingImage = null;
    document.getElementById('imgPreviewWrap').classList.remove('open');
    document.getElementById('imgPreviewThumb').src = '';
}

function prepareQuote(id, text, from) {
    S.pendingQuote = { id, text, from };
    const preview = text.length > 60 ? text.slice(0,60)+'…' : text;
    document.getElementById('quotePreviewText').textContent = preview;
    document.getElementById('quotePreview').classList.add('open');
    document.getElementById('messageInput').focus();
}

function cancelQuote() {
    S.pendingQuote = null;
    document.getElementById('quotePreview').classList.remove('open');
}

function emitTyping() {
    if(S.activeChatType !== 'private' || !S.activeChat) return;
    const k = S.user.uid + '_' + S.activeChat;
    db.ref('typing/' + k).set(S.profile?.nickname || 'Кто-то');
    clearTimeout(S.typingTimer);
    S.typingTimer = setTimeout(() => db.ref('typing/' + k).remove(), 2500);
}

