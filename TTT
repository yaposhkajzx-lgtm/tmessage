// =====================================================
function initCoreData() {
    hideModals();
    nav('messenger');
    updateMiniProfile();
    buildEmojiPicker();
    db.ref().off();
    S.notifReady = false;
    setTimeout(() => { S.notifReady = true; }, 2500);

    initSocialListeners();

    // all contacts (to show other players' friend lists)
    db.ref('contacts').on('value', s => {
        S.allContacts = s.val() || {};
        refreshPlayerProfileIfOpen();
    });

    db.ref('users').on('value', s => {
        S.users = s.val() || {};
        if(S.user && S.users[S.user.uid]) S.profile = S.users[S.user.uid];
        debouncedRenderChats();
        if(S.activeChat && S.activeChatType === 'private') updateActiveChatHeader();
        fillProfileView();
    });

    db.ref('contacts/' + S.user.uid).on('value', s => {
        S.contacts = s.val() || {};
        debouncedRenderChats();
        renderContactsScreen();
    });

    db.ref('messages').on('value', s => {
        S.messages = s.val() || {};
        // re-merge group messages so they aren't wiped by this listener
        Object.entries(S.groupMessages || {}).forEach(([gid, msgs]) => { S.messages[gid] = msgs; });
        debouncedRenderChats();
        if(S.activeChatType === 'private') renderMessages();
        checkUnreadAndNotify();
        updateNavBadge();
    });

    db.ref('groups').on('value', s => {
        S.groups = s.val() || {};
        debouncedRenderChats();
        if(S.activeChatType === 'group') updateActiveChatHeader();
    });

    db.ref('groupMessages').on('value', s => {
        const gm = s.val() || {};
        S.groupMessages = gm;
        Object.entries(gm).forEach(([gid, msgs]) => { S.messages[gid] = msgs; });
        debouncedRenderChats();
        if(S.activeChatType === 'group') renderMessages();
        checkUnreadAndNotify();
        updateNavBadge();
    });

    db.ref('typing').on('value', s => {
        const t = s.val() || {};
        const bar = document.getElementById('typingBar');
        if(S.activeChatType === 'private' && S.activeChat) {
            const k = S.activeChat + '_' + S.user.uid;
            if(t[k]) {
                document.getElementById('typingName').textContent = t[k];
                bar.style.display = 'block';
            } else {
                bar.style.display = 'none';
            }
        } else {
            bar.style.display = 'none';
        }
    });

    window.addEventListener('beforeunload', () => {
        if(S.user) db.ref('users/' + S.user.uid).update({ online: false, lastSeen: Date.now() });
    });
}

function updateMiniProfile() {
    if(!S.profile) return;
    const av = document.getElementById('myAvatarTop');
    av.innerHTML = S.profile.avatar
        ? `<img src="${S.profile.avatar}" alt="">`
        : escapeHtml(S.profile.nickname[0].toUpperCase());
    av.title = S.profile.nickname;
}

function getChatId(u1, u2) { return [u1, u2].sort().join('_'); }

function updateNavBadge() {
    let total = 0;
    // Private chats
    Object.keys(S.messages).forEach(cid => {
        const parts = cid.split('_');
        if(parts.length === 2 && (parts[0] === S.user.uid || parts[1] === S.user.uid)) {
            const uid = parts[0] === S.user.uid ? parts[1] : parts[0];
            if(S.contacts[uid]?.blocked) return;
            Object.values(S.messages[cid]).forEach(m => {
                if(m.from !== S.user.uid && !m.read) total++;
            });
        }
    });
    // Group chats — only count if we are member
    Object.entries(S.groups).forEach(([gid, g]) => {
        if(!g.members || !g.members.includes(S.user.uid)) return;
        const msgs = S.groupMessages[gid] || {};
        const readKey = `groupRead_${gid}_${S.user.uid}`;
        const lastRead = parseInt(localStorage.getItem(readKey) || '0');
        Object.values(msgs).forEach(m => {
            if(m.from !== S.user.uid && (m.time || 0) > lastRead) total++;
        });
    });
    const badge = document.getElementById('navBadgeMsg');
    if(total > 0) { badge.textContent = total > 99 ? '99+' : total; badge.style.display = 'inline-block'; }
    else badge.style.display = 'none';
}

