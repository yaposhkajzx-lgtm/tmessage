<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, maximum-scale=1.0, viewport-fit=cover">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="T-Message">
    <meta name="theme-color" content="#1c1c1e">
    <title>T-Message</title>
    
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-auth-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-database-compat.js"></script>

    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        
        :root {
            --bg-body: #1c1c1e;
            --bg-nav: #18181a;
            --bg-panel: #232328;
            --bg-chat: #1e1e24;
            --bg-hover: #2b2d31;
            --bg-input: #2b2d31;
            --accent: #5865F2;
            --accent-hover: #4752c4;
            --text-main: #f2f3f5;
            --text-muted: #949ba4;
            --border: #2a2a30;
            --online: #23a559;
            --danger: #da373c;
            --warning: #f0a433;
            --top-height: 60px;
            --nav-width: 240px;
        }

        body.theme-dark    { --bg-body:#1c1c1e; --bg-nav:#18181a; --bg-panel:#232328; --bg-chat:#1e1e24; --bg-hover:#2b2d31; --bg-input:#2b2d31; --text-main:#f2f3f5; --text-muted:#949ba4; --border:#2a2a30; }
        body.theme-light   { --bg-body:#f2f3f5; --bg-nav:#e3e5e8; --bg-panel:#ffffff; --bg-chat:#f8f9fa; --bg-hover:#ebedef; --bg-input:#ebedef; --text-main:#060607; --text-muted:#4e5058; --border:#d4d7dc; }
        body.theme-amoled  { --bg-body:#000000; --bg-nav:#0a0a0a; --bg-panel:#111111; --bg-chat:#080808; --bg-hover:#1a1a1a; --bg-input:#1a1a1a; --text-main:#ffffff; --text-muted:#888888; --border:#222222; }
        body.theme-blue    { --bg-body:#0d1117; --bg-nav:#0a0e14; --bg-panel:#161b22; --bg-chat:#0d1117; --bg-hover:#21262d; --bg-input:#21262d; --accent:#007aff; --accent-hover:#0066dd; --text-main:#e6edf3; --text-muted:#7d8590; --border:#30363d; }
        body.theme-green   { --bg-body:#0d1a0d; --bg-nav:#091209; --bg-panel:#122112; --bg-chat:#0d1a0d; --bg-hover:#1a2e1a; --bg-input:#1a2e1a; --accent:#23a559; --accent-hover:#1a8045; --text-main:#e6f4e6; --text-muted:#7a9e7a; --border:#1e3c1e; }
        body.theme-purple  { --bg-body:#120d1e; --bg-nav:#0e0a18; --bg-panel:#1a1228; --bg-chat:#120d1e; --bg-hover:#241830; --bg-input:#241830; --accent:#9b59f7; --accent-hover:#7c3aed; --text-main:#ede8ff; --text-muted:#9580c0; --border:#2e2048; }
        body.theme-rose    { --bg-body:#1e0d12; --bg-nav:#180a0e; --bg-panel:#28121a; --bg-chat:#1e0d12; --bg-hover:#3a1624; --bg-input:#3a1624; --accent:#f43f6a; --accent-hover:#e01050; --text-main:#ffe8ee; --text-muted:#c07080; --border:#4a1c2c; }
        body.theme-sunset  { --bg-body:#1a110a; --bg-nav:#140d06; --bg-panel:#241810; --bg-chat:#1a110a; --bg-hover:#2e1e12; --bg-input:#2e1e12; --accent:#f97316; --accent-hover:#ea6004; --text-main:#fff0e8; --text-muted:#c09070; --border:#3c2010; }
        body.theme-ocean   { --bg-body:#091520; --bg-nav:#060f18; --bg-panel:#0f1e2e; --bg-chat:#091520; --bg-hover:#162840; --bg-input:#162840; --accent:#06b6d4; --accent-hover:#0891b2; --text-main:#e0f8ff; --text-muted:#5a9ab0; --border:#1a3050; }
        body.theme-slate   { --bg-body:#0f172a; --bg-nav:#0a1020; --bg-panel:#1e293b; --bg-chat:#0f172a; --bg-hover:#253452; --bg-input:#253452; --accent:#64748b; --accent-hover:#475569; --text-main:#e2e8f0; --text-muted:#94a3b8; --border:#334155; }

        body { 
            background: var(--bg-body); 
            color: var(--text-main); 
            height: 100vh; 
            overflow: hidden; 
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        }

        .app-container { width: 100%; height: 100vh; display: flex; flex-direction: column; overflow: hidden; }

        .top-bar { 
            height: var(--top-height); 
            background: var(--bg-nav); 
            border-bottom: 1px solid var(--border); 
            display: flex; align-items: center; 
            padding: 0 16px; 
            justify-content: space-between; 
            z-index: 100; 
            flex-shrink: 0;
            gap: 12px;
        }
        .logo-area { display: flex; align-items: center; gap: 10px; font-weight: 800; font-size: 17px; letter-spacing: .5px; color: var(--accent); min-width: 180px; flex-shrink: 0; }
        .logo-icon { font-size: 22px; }
        .global-search { flex: 1; max-width: 480px; position: relative; }
        .global-search input { 
            width: 100%; 
            padding: 9px 14px 9px 38px; 
            border-radius: 8px; 
            background: var(--bg-input); 
            border: 1px solid transparent; 
            color: var(--text-main); 
            outline: none; 
            font-size: 14px;
            transition: border-color .15s;
        }
        .global-search input:focus { border-color: var(--accent); }
        .global-search .search-icon { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-size: 14px; pointer-events: none; }
        
        .search-dropdown { 
            position: absolute; top: calc(100% + 6px); left: 0; right: 0; 
            background: var(--bg-panel); border: 1px solid var(--border); border-radius: 10px; 
            overflow: hidden; display: none; z-index: 500; box-shadow: 0 8px 24px rgba(0,0,0,.4);
        }
        .search-dropdown.open { display: block; }
        .search-item { 
            display: flex; align-items: center; gap: 10px; padding: 10px 14px; 
            cursor: pointer; transition: background .1s; font-size: 14px;
        }
        .search-item:hover { background: var(--bg-hover); }
        .search-item-avatar { width: 32px; height: 32px; border-radius: 50%; background: var(--accent); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 13px; overflow: hidden; flex-shrink: 0; }
        .search-item-avatar img { width: 100%; height: 100%; object-fit: cover; }
        .search-item-info { flex: 1; min-width: 0; }
        .search-item-name { font-weight: 600; }
        .search-item-sub { font-size: 12px; color: var(--text-muted); }

        .top-actions { display: flex; align-items: center; gap: 8px; }
        .icon-btn { 
            width: 36px; height: 36px; border-radius: 8px; background: var(--bg-input); 
            border: none; color: var(--text-main); display: flex; align-items: center; 
            justify-content: center; cursor: pointer; transition: background .15s; font-size: 17px; 
            position: relative;
        }
        .icon-btn:hover { background: var(--bg-hover); }
        .top-avatar { 
            width: 36px; height: 36px; border-radius: 50%; background: var(--accent); 
            display: flex; align-items: center; justify-content: center; 
            font-weight: 700; cursor: pointer; overflow: hidden; font-size: 15px;
            border: 2px solid transparent; transition: border-color .15s;
        }
        .top-avatar:hover { border-color: var(--accent); }
        .top-avatar img { width: 100%; height: 100%; object-fit: cover; }

        .main-wrapper { flex: 1; display: flex; overflow: hidden; }

        .side-nav { 
            width: var(--nav-width); background: var(--bg-body); 
            padding: 12px 8px; display: flex; flex-direction: column; gap: 3px; 
            flex-shrink: 0; border-right: 1px solid var(--border); overflow-y: auto;
        }
        .nav-section-label { 
            font-size: 10px; font-weight: 700; letter-spacing: 1.5px; color: var(--text-muted); 
            padding: 12px 12px 4px; text-transform: uppercase;
        }
        .nav-item { 
            display: flex; align-items: center; gap: 11px; padding: 10px 14px; border-radius: 8px; 
            color: var(--text-muted); cursor: pointer; transition: all .15s; font-weight: 500; font-size: 14px;
            position: relative;
        }
        .nav-item:hover { background: var(--bg-hover); color: var(--text-main); }
        .nav-item.active { background: var(--accent); color: #fff; }
        .nav-item .icon { font-size: 18px; flex-shrink: 0; }
        .nav-badge { 
            margin-left: auto; background: var(--danger); color: #fff; font-size: 10px; 
            padding: 2px 5px; border-radius: 8px; font-weight: 700; min-width: 18px; text-align: center;
        }
        .nav-divider { height: 1px; background: var(--border); margin: 6px 8px; }
        .nav-bottom { margin-top: auto; padding: 10px 12px; font-size: 11px; color: var(--text-muted); text-align: center; line-height: 1.6; }

        .screen-container { flex: 1; display: flex; overflow: hidden; }
        .screen { display: none; width: 100%; height: 100%; overflow: hidden; }
        .screen.active { display: flex; animation: fadeIn .18s ease; }

        /* MESSENGER */
        #messengerScreen { flex-direction: row; }
        
        .chat-list-panel { 
            width: 320px; background: var(--bg-panel); border-right: 1px solid var(--border); 
            display: flex; flex-direction: column; flex-shrink: 0; 
        }
        .clp-header { 
            padding: 14px 16px 10px; display: flex; align-items: center; 
            justify-content: space-between; border-bottom: 1px solid var(--border); 
        }
        .clp-title { font-weight: 700; font-size: 17px; }
        .clp-tools { display: flex; gap: 8px; }
        .clp-search-wrap { padding: 10px 12px; position: relative; }
        .clp-search-wrap input { 
            width: 100%; padding: 8px 12px 8px 34px; background: var(--bg-input); 
            border: 1px solid transparent; border-radius: 8px; color: var(--text-main); 
            outline: none; font-size: 13px; transition: border-color .15s;
        }
        .clp-search-wrap input:focus { border-color: var(--accent); }
        .clp-search-wrap .si { position: absolute; left: 22px; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-size: 13px; }

        .chat-tabs { display: flex; padding: 0 12px; border-bottom: 1px solid var(--border); }
        .chat-tab { 
            padding: 9px 12px; color: var(--text-muted); cursor: pointer; 
            font-size: 13px; font-weight: 500; position: relative; display: flex; align-items: center; gap: 5px;
            border-bottom: 2px solid transparent; margin-bottom: -1px; transition: color .15s;
        }
        .chat-tab:hover { color: var(--text-main); }
        .chat-tab.active { color: var(--text-main); border-bottom-color: var(--accent); }
        .tab-badge { background: var(--bg-input); padding: 1px 5px; border-radius: 8px; font-size: 11px; }

        .chats-scroll { flex: 1; overflow-y: auto; padding: 6px; }
        
        .chat-item { 
            display: flex; align-items: center; gap: 11px; padding: 9px 10px; 
            border-radius: 10px; cursor: pointer; transition: background .15s; 
            position: relative; overflow: hidden; margin-bottom: 1px; 
        }
        .chat-item:hover { background: var(--bg-hover); }
        .chat-item.active { background: var(--bg-input); box-shadow: inset 3px 0 0 var(--accent); }
        .chat-item.active .ci-name { color: var(--accent); }
        
        .ci-avatar { 
            width: 46px; height: 46px; border-radius: 50%; background: var(--accent); 
            display: flex; align-items: center; justify-content: center; font-weight: 700; 
            font-size: 17px; flex-shrink: 0; position: relative; overflow: hidden; 
        }
        .ci-avatar img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }
        .status-dot { 
            width: 12px; height: 12px; background: var(--online); border: 2px solid var(--bg-panel); 
            border-radius: 50%; position: absolute; bottom: 0; right: 0; display: none; 
        }
        .chat-item.is-online .status-dot { display: block; }
        
        .ci-info { flex: 1; min-width: 0; }
        .ci-row1 { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 3px; }
        .ci-name { font-weight: 600; font-size: 14px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 170px; }
        .ci-time { font-size: 11px; color: var(--text-muted); flex-shrink: 0; }
        .ci-row2 { display: flex; align-items: center; gap: 4px; }
        .ci-last { font-size: 12px; color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex: 1; }
        .ci-unread { 
            background: var(--accent); color: #fff; font-size: 10px; padding: 2px 5px; 
            border-radius: 8px; font-weight: 700; min-width: 18px; text-align: center; flex-shrink: 0;
        }

        .ci-actions { 
            position: absolute; right: 0; top: 0; bottom: 0; display: flex; 
            background: linear-gradient(to right, transparent, var(--bg-panel) 20%);
            transform: translateX(100%); transition: transform .25s; z-index: 5; 
        }
        .chat-item.swiped .ci-actions { transform: translateX(0); }
        .ci-actions button { 
            border: none; color: #fff; width: 52px; cursor: pointer; font-size: 17px; 
            display: flex; align-items: center; justify-content: center; 
        }

        .chat-window { flex: 1; background: var(--bg-chat); display: flex; flex-direction: column; position: relative; }
        
        .cw-header { 
            height: 60px; padding: 0 18px; display: flex; align-items: center; 
            justify-content: space-between; border-bottom: 1px solid var(--border); 
            background: var(--bg-chat); z-index: 10; flex-shrink: 0;
        }
        .cwh-left { display: flex; align-items: center; gap: 12px; }
        .cwh-info h3 { font-size: 15px; font-weight: 700; margin-bottom: 2px; cursor: pointer; }
        .cwh-info h3:hover { text-decoration: underline; }
        .cwh-status { font-size: 12px; color: var(--online); }
        .cwh-status.offline { color: var(--text-muted); }
        .cwh-tools { display: flex; gap: 10px; color: var(--text-muted); }
        .cwh-btn { 
            width: 34px; height: 34px; border-radius: 8px; display: flex; align-items: center; 
            justify-content: center; cursor: pointer; font-size: 17px; transition: all .15s;
        }
        .cwh-btn:hover { background: var(--bg-hover); color: var(--text-main); }

        .chat-empty-state { 
            flex: 1; display: flex; flex-direction: column; align-items: center; 
            justify-content: center; color: var(--text-muted); gap: 12px; text-align: center; padding: 40px;
        }
        .chat-empty-state .big-icon { font-size: 52px; opacity: .5; }
        .chat-empty-state h3 { font-size: 18px; color: var(--text-main); }
        .chat-empty-state p { font-size: 14px; max-width: 260px; line-height: 1.5; }

        .messages-area { 
            flex: 1; overflow-y: auto; padding: 16px 18px; 
            display: flex; flex-direction: column; gap: 2px;
        }
        
        .date-divider { text-align: center; margin: 10px 0; user-select: none; }
        .date-divider span { 
            background: rgba(0,0,0,.2); padding: 4px 12px; border-radius: 12px; 
            font-size: 11px; color: var(--text-muted); 
        }

        .msg-row { display: flex; width: 100%; align-items: flex-end; gap: 8px; position: relative; }
        .msg-row.sent { justify-content: flex-end; }
        .msg-row.recv { justify-content: flex-start; }
        .msg-row + .msg-row { margin-top: 2px; }

        .msg-side-avatar { 
            width: 30px; height: 30px; border-radius: 50%; background: var(--accent); 
            display: flex; align-items: center; justify-content: center; font-size: 11px; 
            font-weight: 700; flex-shrink: 0; overflow: hidden; cursor: pointer;
            opacity: 1; transition: opacity .15s; align-self: flex-end;
        }
        .msg-side-avatar img { width: 100%; height: 100%; object-fit: cover; }
        .msg-side-avatar.hidden { opacity: 0; pointer-events: none; }
        .msg-row.sent .msg-side-avatar { order: 2; }
        .msg-row.recv .msg-side-avatar { order: 0; }

        .msg-bubble { 
            max-width: 62%; background: var(--bg-input); padding: 9px 13px 7px; 
            border-radius: 14px; position: relative; color: var(--text-main); 
            font-size: 14px; line-height: 1.45; word-wrap: break-word; 
            order: 1;
        }
        .msg-row.sent .msg-bubble { border-bottom-right-radius: 4px; background: var(--accent); }
        .msg-row.recv .msg-bubble { border-bottom-left-radius: 4px; }
        
        .msg-row.sent.tail .msg-bubble::after {
            content: ''; position: absolute; bottom: 0; right: -6px;
            border: 7px solid transparent; border-top-color: var(--accent); border-right: none;
        }
        .msg-row.recv.tail .msg-bubble::after {
            content: ''; position: absolute; bottom: 0; left: -6px;
            border: 7px solid transparent; border-top-color: var(--bg-input); border-left: none;
        }

        .msg-author { font-weight: 700; font-size: 12px; margin-bottom: 3px; cursor: pointer; }

        .sys-msg { text-align: center; margin: 10px 0; }
        .sys-msg span {
            display: inline-block; background: var(--bg-input); color: var(--text-muted);
            font-size: 12px; padding: 4px 12px; border-radius: 12px; max-width: 80%;
        }

        /* REACTIONS */
        .msg-reactions { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 5px; }
        .reaction-pill {
            display: inline-flex; align-items: center; gap: 3px; padding: 2px 7px;
            background: rgba(0,0,0,.22); border: 1px solid transparent; border-radius: 11px;
            font-size: 12px; cursor: pointer; transition: all .12s; user-select: none; line-height: 1.4;
        }
        .msg-row.recv .reaction-pill { background: rgba(255,255,255,.06); }
        .reaction-pill:hover { background: rgba(0,0,0,.34); }
        .reaction-pill.mine { background: var(--accent); border-color: rgba(255,255,255,.35); color: #fff; }
        .reaction-pill .rc-count { font-weight: 700; font-size: 11px; }

        .react-btn {
            position: absolute; background: var(--bg-panel); width: 26px; height: 26px;
            border-radius: 50%; display: flex; align-items: center; justify-content: center;
            cursor: pointer; opacity: 0; transition: opacity .15s; border: 1px solid var(--border);
            font-size: 14px; top: -11px; z-index: 12; box-shadow: 0 2px 6px rgba(0,0,0,.3);
        }
        .msg-row.recv .react-btn { right: -8px; }
        .msg-row.sent .react-btn { left: -8px; }
        .msg-row:hover .react-btn { opacity: 1; }
        .react-btn:hover { transform: scale(1.12); }

        .react-popup {
            position: fixed; background: var(--bg-panel); border: 1px solid var(--border);
            border-radius: 24px; padding: 6px 8px; display: none; gap: 4px; z-index: 9999;
            box-shadow: 0 8px 28px rgba(0,0,0,.45);
        }
        .react-popup.open { display: flex; }
        .react-popup .rp-emoji {
            width: 38px; height: 38px; display: flex; align-items: center; justify-content: center;
            font-size: 22px; cursor: pointer; border-radius: 50%; transition: transform .12s, background .12s;
        }
        .react-popup .rp-emoji:hover { transform: scale(1.25); background: var(--bg-hover); }

        .msg-edited { font-size: 10px; opacity: .5; margin-left: 4px; font-style: italic; }

        .msg-quote { 
            border-left: 3px solid rgba(255,255,255,.4); padding: 5px 8px; margin-bottom: 6px; 
            font-size: 12px; opacity: .8; border-radius: 4px; background: rgba(0,0,0,.15); 
            cursor: pointer;
        }
        .msg-row.recv .msg-quote { border-left-color: var(--accent); }
        .msg-img { 
            max-width: 100%; max-height: 280px; border-radius: 8px; margin-top: 5px; 
            cursor: pointer; object-fit: cover; display: block;
        }
        .msg-footer { 
            display: flex; align-items: center; justify-content: flex-end; gap: 4px; 
            margin-top: 4px; 
        }
        .msg-time { font-size: 10px; opacity: .6; }
        .msg-check { font-size: 11px; opacity: .7; }
        .msg-check.read { opacity: 1; color: #a8d8ea; }
        .msg-row.recv .msg-check { display: none; }

        .msg-reply-trigger {
            position: absolute; background: var(--bg-panel); width: 28px; height: 28px; 
            border-radius: 50%; display: flex; align-items: center; justify-content: center; 
            cursor: pointer; opacity: 0; transition: opacity .2s; border: 1px solid var(--border);
            font-size: 14px; top: 50%; transform: translateY(-50%); z-index: 10;
        }
        .msg-row.sent .msg-reply-trigger { left: -38px; }
        .msg-row.recv .msg-reply-trigger { right: -38px; }
        @media (hover: hover) { .msg-row:hover .msg-reply-trigger { opacity: 1; } }

        .ctx-menu {
            position: fixed; background: var(--bg-panel); border: 1px solid var(--border);
            border-radius: 10px; box-shadow: 0 8px 24px rgba(0,0,0,.5); 
            z-index: 1000; min-width: 160px; overflow: hidden; display: none;
            animation: fadeIn .12s ease;
        }
        .ctx-menu.open { display: block; }
        .ctx-item { 
            padding: 10px 14px; cursor: pointer; font-size: 13px; display: flex; 
            align-items: center; gap: 9px; transition: background .1s; 
        }
        .ctx-item:hover { background: var(--bg-hover); }
        .ctx-item.danger { color: var(--danger); }
        .ctx-divider { height: 1px; background: var(--border); }

        .typing-bar { 
            position: absolute; bottom: 72px; left: 18px; 
            background: var(--bg-panel); border: 1px solid var(--border); 
            border-radius: 12px; padding: 6px 12px; font-size: 12px; 
            color: var(--text-muted); font-style: italic; display: none; z-index: 10;
            animation: fadeIn .2s ease;
        }
        .typing-dots { display: inline-flex; gap: 3px; margin-left: 5px; }
        .typing-dots span { 
            width: 4px; height: 4px; background: var(--text-muted); border-radius: 50%; 
            animation: blink 1.4s infinite; 
        }
        .typing-dots span:nth-child(2) { animation-delay: .2s; }
        .typing-dots span:nth-child(3) { animation-delay: .4s; }
        @keyframes blink { 0%,80%,100%{opacity:.2} 40%{opacity:1} }

        .input-area { padding: 10px 14px 12px; background: var(--bg-chat); flex-shrink: 0; }
        .quote-preview { 
            display: none; background: var(--bg-input); border-radius: 8px 8px 0 0; 
            padding: 8px 12px; border-left: 4px solid var(--accent); 
