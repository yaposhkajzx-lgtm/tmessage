function eligibleForGroup(uid) {
    if(uid === S.user.uid) return false;
    const u = S.users[uid]; if(!u) return false;
    if(u.banned) return false;
    if(S.activeChatType === 'group' && (S.groups[S.activeChat]?.members || []).includes(uid)) return false;
    // (#12) who can add me to groups
    const ga = u.groupAddVis || 'all';
    if(ga === 'nobody') return false;
    if(ga === 'contacts' && !S.contacts[uid]) return false;
    return true;
}

function renderMemberPickList() {
    const q = document.getElementById('memberPickSearch').value.trim().toLowerCase();
    const list = document.getElementById('memberPickList');
    // friends first, then other eligible users
    const ids = Object.keys(S.users).filter(eligibleForGroup).filter(uid => {
        if(!q) return true;
        const u = S.users[uid];
        return (u.nickname||'').toLowerCase().includes(q) || (u.username||'').toLowerCase().includes(q);
    }).sort((a,b) => {
        const fa = S.contacts[a] ? 0 : 1, fb = S.contacts[b] ? 0 : 1;
        if(fa !== fb) return fa - fb;
        return (S.users[a].nickname||'').localeCompare(S.users[b].nickname||'');
    });
    if(!ids.length) { list.innerHTML = '<p style="text-align:center;color:var(--text-muted);padding:20px;font-size:13px;">Нет доступных игроков</p>'; return; }
    list.innerHTML = ids.map(uid => {
        const u = S.users[uid];
        const av = u.avatar ? `<img src="${u.avatar}" alt="">` : escapeHtml((u.nickname||'?')[0].toUpperCase());
        const isFriend = !!S.contacts[uid];
        return `<div class="member-pick-row ${pickedMembers.has(uid)?'checked':''}" onclick="toggleMemberPick('${uid}', this)">
            <div class="mp-av">${av}</div>
            <div class="mp-info">
                <div style="font-weight:600;">${escapeHtml(u.nickname||'?')}</div>
                <div style="font-size:12px;color:var(--text-muted);">${isFriend?'👥 Друг':''}${u.online?' <span style="color:var(--online)">● онлайн</span>':''}</div>
            </div>
            <div class="mp-check">${pickedMembers.has(uid)?'✓':''}</div>
        </div>`;
    }).join('');
}

function toggleMemberPick(uid, el) {
    if(pickedMembers.has(uid)) { pickedMembers.delete(uid); el.classList.remove('checked'); el.querySelector('.mp-check').textContent=''; }
    else { pickedMembers.add(uid); el.classList.add('checked'); el.querySelector('.mp-check').textContent='✓'; }
}

async function confirmAddMembers() {
    if(!pickedMembers.size) return showToast('Выберите хотя бы одного игрока');
    if(S.activeChatType === 'group' && S.activeChat) {
        const g = S.groups[S.activeChat];
        const newMembers = [...new Set([...(g.members||[]), ...pickedMembers])];
        await db.ref('groups/' + S.activeChat + '/members').set(newMembers);
        for(const uid of pickedMembers) {
            await pushNotification(uid, { type: 'group_add', groupName: g.name });
            await groupSystemMsg(S.activeChat, `${myName()} добавил(-а) ${nameOf(uid)}`);
        }
        showToast(`Добавлено: ${pickedMembers.size}`);
    }
    hideModals();
    setTimeout(() => { if(S.activeChatType==='group') showChatInfo(); }, 300);
}

// =====================================================
// POSTS SYSTEM (#9)
// =====================================================
let pendingPostImage = null;
function selectPostImage(e) {
    const f = e.target.files[0]; if(!f) return;
    if(f.size > 4 * 1024 * 1024) return showToast('Фото больше 4 МБ');
    const r = new FileReader();
    r.onload = ev => {
        pendingPostImage = ev.target.result;
        document.getElementById('pcPreviewImg').src = pendingPostImage;
        document.getElementById('pcPreview').classList.add('show');
    };
    r.readAsDataURL(f);
    e.target.value = '';
}
function clearPostImage() {
    pendingPostImage = null;
    document.getElementById('pcPreview').classList.remove('show');
    document.getElementById('pcPreviewImg').src = '';
}
async function publishPost() {
    const caption = document.getElementById('postCaptionInput').value.trim();
    if(!caption && !pendingPostImage) return showToast('Добавьте текст или фото');
    const post = {
        author: S.user.uid, caption: caption || '', time: firebase.database.ServerValue.TIMESTAMP,
        likes: {}, comments: {}, views: {}
    };
    if(pendingPostImage) post.image = pendingPostImage;
    await db.ref('posts').push(post);
    document.getElementById('postCaptionInput').value = '';
    clearPostImage();
    showToast('✅ Опубликовано');
}

async function toggleLike(postId) {
    const p = S.posts[postId]; if(!p) return;
    const ref = db.ref(`posts/${postId}/likes/${S.user.uid}`);
    if(p.likes && p.likes[S.user.uid]) {
        await ref.remove();
    } else {
        await ref.set(true);
        if(p.author !== S.user.uid) await pushNotification(p.author, { type: 'like', postId });
    }
}

function toggleComments(postId) {
    if(!S.openComments) S.openComments = new Set();
    const el = document.getElementById('comments_' + postId);
    if(el) {
        const willOpen = !el.classList.contains('open');
        el.classList.toggle('open');
        if(willOpen) S.openComments.add(postId); else S.openComments.delete(postId);
    }
}

async function addComment(postId, inputEl) {
    const text = inputEl.value.trim();
    if(!text) return;
    const p = S.posts[postId]; if(!p) return;
    await db.ref(`posts/${postId}/comments`).push({ from: S.user.uid, text, time: firebase.database.ServerValue.TIMESTAMP });
    inputEl.value = '';
    if(p.author !== S.user.uid) await pushNotification(p.author, { type: 'comment', postId });
}

async function deletePost(postId) {
    if(!await customConfirm('Удалить пост', 'Удалить публикацию навсегда?')) return;
    await db.ref('posts/' + postId).remove();
    showToast('Пост удалён');
}

function registerPostView(postId) {
    const p = S.posts[postId];
    if(!p) return;
    if(p.views && p.views[S.user.uid]) return; // already counted this viewer
    db.ref(`posts/${postId}/views/${S.user.uid}`).set(true);
}

function postCardHTML(postId, p) {
    const u = S.users[p.author] || {};
    const av = u.avatar ? `<img src="${u.avatar}" alt="">` : escapeHtml((u.nickname||'?')[0].toUpperCase());
    const likeCount = p.likes ? Object.keys(p.likes).length : 0;
    const liked = p.likes && p.likes[S.user.uid];
    const viewCount = p.views ? Object.keys(p.views).length : 0;
    const comments = p.comments ? Object.entries(p.comments).sort((a,b)=>(a[1].time||0)-(b[1].time||0)) : [];
    const isMine = p.author === S.user.uid;

    const commentsHTML = comments.map(([cid, c]) => {
        const cu = S.users[c.from] || {};
        const cav = cu.avatar ? `<img src="${cu.avatar}" alt="">` : escapeHtml((cu.nickname||'?')[0].toUpperCase());
        return `<div class="comment-row">
            <div class="cm-av" onclick="openPlayerProfile('${c.from}')">${cav}</div>
            <div class="comment-bubble">
                <div class="cm-name" onclick="openPlayerProfile('${c.from}')">${escapeHtml(cu.nickname||'?')}</div>
                <div class="cm-text">${escapeHtml(c.text)}</div>
            </div>
        </div>`;
    }).join('');

    return `<div class="post-card" data-postid="${postId}">
        <div class="post-head">
            <div class="ph-av" onclick="openPlayerProfile('${p.author}')">${av}</div>
            <div>
                <div class="ph-name" onclick="openPlayerProfile('${p.author}')">${escapeHtml(u.nickname||'?')}</div>
                <div class="ph-time">${formatLastSeen(p.time || Date.now())}</div>
            </div>
            ${isMine ? `<div class="ph-menu" onclick="deletePost('${postId}')" title="Удалить">🗑</div>` : ''}
        </div>
        ${p.caption ? `<div class="post-caption">${escapeHtml(p.caption).replace(/\n/g,'<br>')}</div>` : ''}
        ${p.image ? `<img src="${p.image}" class="post-image" onclick="openLightbox('${p.image}')" alt="Пост">` : ''}
        <div class="post-stats-bar">
            <div class="post-act ${liked?'liked':''}" onclick="toggleLike('${postId}')">
                <span class="pa-ic">${liked?'❤️':'🤍'}</span><span>${likeCount}</span>
            </div>
            <div class="post-act" onclick="toggleComments('${postId}')">
                <span class="pa-ic">💬</span><span>${comments.length}</span>
            </div>
            <div class="post-views" title="Просмотры">👁 ${viewCount}</div>
        </div>
        <div class="post-comments${S.openComments && S.openComments.has(postId) ? ' open' : ''}" id="comments_${postId}">
            ${commentsHTML || '<p style="color:var(--text-muted);font-size:13px;margin-bottom:8px;">Пока нет комментариев</p>'}
            <div class="comment-input-row">
                <input type="text" placeholder="Написать комментарий..." onkeydown="if(event.key==='Enter')addComment('${postId}', this)">
                <button class="btn" style="padding:8px 14px;font-size:13px;" onclick="addComment('${postId}', this.previousElementSibling)">➤</button>
            </div>
        </div>
    </div>`;
}

function sortedPosts(filterFn) {
    return Object.entries(S.posts || {})
        .filter(([id, p]) => p && (!filterFn || filterFn(p)))
        .sort((a, b) => (b[1].time || 0) - (a[1].time || 0));
}

function renderMyPosts() {
    const c = document.getElementById('myPostsContainer'); if(!c) return;
    const mine = sortedPosts(p => p.author === S.user.uid);
    c.innerHTML = mine.length ? mine.map(([id, p]) => postCardHTML(id, p)).join('')
        : '<div class="posts-empty">У вас пока нет публикаций. Поделитесь чем-нибудь!</div>';
    mine.forEach(([id]) => registerPostView(id));
}

function renderFeed() {
    const c = document.getElementById('feedContainer'); if(!c) return;
    // posts from me + my friends
    const allowed = new Set([S.user.uid, ...Object.keys(S.contacts || {})]);
    const feed = sortedPosts(p => allowed.has(p.author));
    c.innerHTML = feed.length ? feed.map(([id, p]) => postCardHTML(id, p)).join('')
        : '<div class="posts-empty">Лента пуста. Добавьте друзей и публикуйте посты!</div>';
    feed.forEach(([id]) => registerPostView(id));
}

// =====================================================
// PLAYER PROFILE (#5, #6)
// =====================================================
function openPlayerProfile(uid) {
    if(uid === S.user.uid) { nav('profile'); return; }
    const u = S.users[uid]; if(!u) return showToast('Игрок не найден');
    S.viewingPlayer = uid;
    closeNotifPanel();
    nav('playerProfile');
    renderPlayerProfile();
    switchPlayerTab('posts');
}

function refreshPlayerProfileIfOpen() {
    if(S.viewingPlayer && document.getElementById('playerProfileScreen').classList.contains('active')) {
        renderPlayerProfile();
        const activeTab = document.querySelector('.pp-tab.active')?.dataset.pptab || 'posts';
        switchPlayerTab(activeTab);
    }
}

function playerPrivacy(uid) {
    // returns {blockedMe, canSee}
    const u = S.users[uid] || {};
    const theyBlockedMe = !!(S.allContacts?.[uid]?.[S.user.uid]?.blocked);
    const isFriend = !!S.contacts[uid];
    const vis = u.vis || 'all';
    const canSee = !theyBlockedMe && (vis === 'all' || (vis === 'contacts' && isFriend));
    return { theyBlockedMe, canSee, vis };
}

function renderPlayerProfile() {
    const uid = S.viewingPlayer; const u = S.users[uid]; if(!u) return;
    const { theyBlockedMe, canSee } = playerPrivacy(uid);
    const av = u.avatar ? `<img src="${u.avatar}" alt="">` : escapeHtml((u.nickname||'?')[0].toUpperCase());
    document.getElementById('ppBigAvatar').innerHTML = av;
    document.getElementById('ppBanner').style.background = `linear-gradient(135deg, ${getUserColor(uid)}, #1a1a2e)`;
    document.getElementById('ppName').textContent = u.nickname || '—';

    const badge = document.getElementById('ppBadge');
    if(u.banned) { badge.style.display='inline-block'; badge.className='badge badge-admin'; badge.textContent='BAN'; }
    else badge.style.display = 'none';

    const btnBox = document.getElementById('ppActionBtn');

    // (#10) they blocked me
    if(theyBlockedMe) {
        document.getElementById('ppBio').textContent = '';
        document.getElementById('ppUser').innerHTML = '';
        document.getElementById('ppStatus').innerHTML = '<span style="color:var(--danger)">Увы, пользователь заблокировал(-а) вас</span>';
        document.getElementById('ppStatFriends').textContent = '—';
        document.getElementById('ppStatPosts').textContent = '—';
        document.getElementById('ppStatLikes').textContent = '—';
        btnBox.innerHTML = '';
        return;
    }

    // (#9, #12) hidden profile
    if(!canSee) {
        document.getElementById('ppBio').textContent = '';
        document.getElementById('ppUser').innerHTML = u.username ? '👤 @' + escapeHtml(u.username) : '';
        document.getElementById('ppStatus').innerHTML = '🔒 Профиль скрыт настройками приватности';
        document.getElementById('ppStatFriends').textContent = '—';
        document.getElementById('ppStatPosts').textContent = '—';
        document.getElementById('ppStatLikes').textContent = '—';
    } else {
        document.getElementById('ppBio').textContent = u.bio || '';
        const isFriend = !!S.contacts[uid];
        const canPhone = (u.phoneVis||'all') === 'all' || ((u.phoneVis||'all') === 'contacts' && isFriend);
        let metaUser = u.username ? '👤 @' + escapeHtml(u.username) : '';
        if(canPhone && u.phone) metaUser += (metaUser ? ' &nbsp; ' : '') + '📞 ' + escapeHtml(u.phone);
        document.getElementById('ppUser').innerHTML = metaUser;
        document.getElementById('ppStatus').innerHTML = u.online ? '<span style="color:var(--online)">🟢 В сети</span>' : '⚫ был(-а) в сети ' + (u.lastSeen ? formatLastSeen(u.lastSeen) : 'давно');
        const friendsCount = mutualFriendsOf(uid).length;
        const posts = sortedPosts(p => p.author === uid);
        let likes = 0; posts.forEach(([id,p]) => likes += p.likes ? Object.keys(p.likes).length : 0);
        document.getElementById('ppStatFriends').textContent = friendsCount;
        document.getElementById('ppStatPosts').textContent = posts.length;
        document.getElementById('ppStatLikes').textContent = likes;
    }

    // action button (friend state)
    const state = getFriendState(uid);
    let btn = '';
    if(state === 'blocked') btn = `<button class="friend-state-btn fsb-friends" onclick="toggleBlock('${uid}')">🔓 Разблокировать</button>`;
    else if(state === 'friends') btn = `<button class="friend-state-btn fsb-friends" onclick="removeFriend('${uid}')">✓ В друзьях</button>
        <button class="friend-state-btn fsb-add" style="margin-left:6px;" onclick="nav('messenger');openChat('${uid}','private')">💬 Написать</button>`;
    else if(state === 'outgoing') btn = `<button class="friend-state-btn fsb-pending" onclick="cancelOutgoingRequest('${uid}')" style="cursor:pointer;">⏳ Заявка отправлена</button>`;
    else if(state === 'incoming') btn = `<button class="friend-state-btn fsb-accept" onclick="acceptFriendRequest('${uid}')">Принять заявку</button>`;
    else btn = `<button class="friend-state-btn fsb-add" onclick="sendFriendRequest('${uid}')">+ Добавить в друзья</button>`;
    btnBox.innerHTML = btn;
}

function switchPlayerTab(tab) {
    document.querySelectorAll('.pp-tab').forEach(t => t.classList.toggle('active', t.dataset.pptab === tab));
    const postsC = document.getElementById('ppPostsContent');
    const friendsC = document.getElementById('ppFriendsContent');
    postsC.style.display = (tab === 'posts') ? 'block' : 'none';
    friendsC.style.display = (tab === 'friends') ? 'block' : 'none';
    const uid = S.viewingPlayer;
    const { theyBlockedMe, canSee } = playerPrivacy(uid);
    if(theyBlockedMe || !canSee) {
        const msg = theyBlockedMe
            ? '<div class="posts-empty">Контент недоступен</div>'
            : '<div class="posts-empty">🔒 Профиль закрыт настройками приватности</div>';
        postsC.innerHTML = msg; friendsC.innerHTML = msg;
        return;
    }
    if(tab === 'posts') {
        const posts = sortedPosts(p => p.author === uid);
        postsC.innerHTML = posts.length ? posts.map(([id, p]) => postCardHTML(id, p)).join('')
            : '<div class="posts-empty">У игрока пока нет публикаций</div>';
        posts.forEach(([id]) => registerPostView(id));
    } else {
        const ids = mutualFriendsOf(uid);
        friendsC.innerHTML = ids.length ? ids.map(fid => {
            const fu = S.users[fid]; if(!fu) return '';
            const fav = fu.avatar ? `<img src="${fu.avatar}" alt="">` : escapeHtml((fu.nickname||'?')[0].toUpperCase());
            return `<div class="friend-req-card">
                <div class="fr-av" onclick="openPlayerProfile('${fid}')">${fav}</div>
                <div class="fr-info" onclick="openPlayerProfile('${fid}')">
                    <div class="fr-name">${escapeHtml(fu.nickname||'?')}</div>
                    <div class="fr-sub">${fu.online?'<span style="color:var(--online)">● в сети</span>':'○ не в сети'}</div>
                </div>
            </div>`;
        }).join('') : '<div class="posts-empty">Список друзей пуст или скрыт</div>';
    }
}

// =====================================================
// NOTIFICATIONS PANEL (#9)
// =====================================================
function toggleNotifPanel() {
    const p = document.getElementById('notifPanel');
    p.classList.toggle('open');
    if(p.classList.contains('open')) { renderNotifs(); setTimeout(markAllNotifsRead, 1500); }
}
function closeNotifPanel() { document.getElementById('notifPanel').classList.remove('open'); }

function notifText(n) {
    const name = escapeHtml(S.users[n.from]?.nickname || 'Игрок');
    switch(n.type) {
        case 'friend_request': return `<b>${name}</b> хочет добавить вас в друзья`;
        case 'friend_accept':  return `<b>${name}</b> принял вашу заявку в друзья`;
        case 'like':           return `<b>${name}</b> оценил вашу публикацию ❤️`;
        case 'comment':        return `<b>${name}</b> прокомментировал вашу публикацию 💬`;
        case 'group_add':      return `<b>${name}</b> добавил вас в группу «${escapeHtml(n.groupName||'')}»`;
        default:               return `<b>${name}</b> — новое уведомление`;
    }
}

function renderNotifs() {
    const list = document.getElementById('notifList'); if(!list) return;
    const items = Object.entries(S.notifications || {}).sort((a,b) => (b[1].time||0)-(a[1].time||0));
    if(!items.length) { list.innerHTML = '<p style="text-align:center;color:var(--text-muted);padding:40px;font-size:14px;">Нет уведомлений</p>'; return; }
    list.innerHTML = items.map(([nid, n]) => {
        const u = S.users[n.from] || {};
        const av = u.avatar ? `<img src="${u.avatar}" alt="">` : escapeHtml((u.nickname||'?')[0].toUpperCase());
        let actionBtns = '';
        if(n.type === 'friend_request' && getFriendState(n.from) === 'incoming') {
            actionBtns = `<div class="nr-btns">
                <button class="friend-state-btn fsb-accept" style="padding:6px 10px;font-size:12px;" onclick="event.stopPropagation();acceptFriendRequest('${n.from}')">✓</button>
                <button class="friend-state-btn fsb-friends" style="padding:6px 10px;font-size:12px;" onclick="event.stopPropagation();declineFriendRequest('${n.from}')">✕</button>
            </div>`;
        }
        return `<div class="notif-row ${n.read?'':'unread'}" onclick="onNotifClick('${nid}','${n.from}','${n.type}')">
            <div class="nr-av">${av}</div>
            <div class="nr-body">
                <div class="nr-text">${notifText(n)}</div>
                <div class="nr-time">${formatLastSeen(n.time || Date.now())}</div>
            </div>
            ${actionBtns}
        </div>`;
    }).join('');
}

function onNotifClick(nid, fromUid, type) {
    db.ref(`notifications/${S.user.uid}/${nid}/read`).set(true);
    if(type === 'like' || type === 'comment') { closeNotifPanel(); nav('profile'); }
    else { openPlayerProfile(fromUid); }
}

async function markAllNotifsRead() {
    const updates = {};
    Object.entries(S.notifications || {}).forEach(([nid, n]) => { if(!n.read) updates[`${nid}/read`] = true; });
    if(Object.keys(updates).length) await db.ref('notifications/' + S.user.uid).update(updates);
}

async function clearAllNotifs() {
    if(!Object.keys(S.notifications || {}).length) return showToast('Уведомлений нет');
    if(!await customConfirm('Очистить уведомления', 'Удалить все уведомления?')) return;
    await db.ref('notifications/' + S.user.uid).remove();
    showToast('Уведомления очищены');
}

function updateNotifDot() {
    const unread = Object.values(S.notifications || {}).filter(n => !n.read).length;
    const dot = document.getElementById('notifDot');
    if(dot) dot.classList.toggle('show', unread > 0);
}
</script>
