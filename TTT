function checkUnreadAndNotify() {
    if(!S.user) return;
    if(!S.notifiedMsgIds) S.notifiedMsgIds = new Set();

    Object.entries(S.messages).forEach(([cid, msgs]) => {
        if(!msgs) return;
        const parts = cid.split('_');
        const isGroup = !!S.groups[cid];
        const isPrivate = parts.length === 2 && (parts[0] === S.user.uid || parts[1] === S.user.uid);
        if(!isGroup && !isPrivate) return;
        // skip groups where I'm not a member or I'm the only member
        if(isGroup) {
            const gm = S.groups[cid]?.members || [];
            if(!gm.includes(S.user.uid) || gm.length < 2) return;
        }

        let pid = null;
        if(isPrivate) pid = parts[0] === S.user.uid ? parts[1] : parts[0];
        if(pid && S.contacts[pid]?.blocked) return;

        Object.entries(msgs).forEach(([mid, m]) => {
            if(m.system || m.from === S.user.uid || m.read || S.notifiedMsgIds.has(mid)) return;
            S.notifiedMsgIds.add(mid);

            // Don't flood with toasts for historical messages on first load
            if(!S.notifReady) return;

            const isActiveChat = isGroup ? cid === S.activeChat : pid === S.activeChat;
            if(isActiveChat) return;

            let senderName, senderText;
            if(isGroup) {
                const g = S.groups[cid];
                senderName = `${S.users[m.from]?.nickname || '?'} → ${g?.name || 'Группа'}`;
            } else {
                senderName = S.users[pid]?.nickname || 'Новое сообщение';
            }
            senderText = m.text || (m.image ? '📷 Фото' : '');

            S.notifData = { id: isGroup ? cid : pid, type: isGroup ? 'group' : 'private' };

            const toast = document.getElementById('notifToast');
            toast.innerHTML = `
                <button class="notif-close" onclick="event.stopPropagation(); this.parentElement.style.display='none'">✕</button>
                <div style="font-weight:700;margin-bottom:3px;">${escapeHtml(senderName)}</div>
                <div style="font-size:12px;color:var(--text-muted);">${escapeHtml(senderText.slice(0,80))}</div>`;
            toast.style.display = 'block';
            clearTimeout(toast._timer);
            toast._timer = setTimeout(() => toast.style.display = 'none', 5000);
        });
    });
}

function handleNotifClick() {
    if(S.notifData) {
        nav('messenger');
        openChat(S.notifData.id, S.notifData.type);
        document.getElementById('notifToast').style.display = 'none';
    }
}

