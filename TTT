auth.onAuthStateChanged(async u => {
    if(u) {
        S.user = u;
        const snap = await db.ref('users/' + u.uid).once('value');
        if(snap.exists()) {
            S.profile = snap.val();
            if(S.profile.banned) {
                auth.signOut();
                showToast("⛔ Аккаунт заблокирован.");
                showModal('welcomeModal'); return;
            }
            db.ref('users/' + u.uid).update({ online: true, lastSeen: Date.now() });
            initCoreData();
        } else {
            showModal('welcomeModal');
        }
    } else {
        S = { ...S, user: null, profile: null, users: {}, contacts: {}, messages: {}, groupMessages: {}, groups: {}, activeChat: null, activeChatType: null, notifiedMsgIds: new Set() };
        showModal('welcomeModal');
    }
});

async function doLogin() {
    const e = document.getElementById('loginEmail').value.trim();
    const p = document.getElementById('loginPass').value;
    if(!e || !p) return showToast("Заполните все поля");
    try {
        await auth.signInWithEmailAndPassword(e, p);
        hideModals();
    } catch(err) {
        showToast(friendlyAuthError(err.code));
    }
}

function friendlyAuthError(code) {
    const map = {
        'auth/user-not-found': 'Пользователь не найден',
        'auth/wrong-password': 'Неверный пароль',
        'auth/invalid-email': 'Некорректный email',
        'auth/email-already-in-use': 'Email уже занят',
        'auth/weak-password': 'Слишком простой пароль',
        'auth/too-many-requests': 'Слишком много попыток, подождите',
        'auth/network-request-failed': 'Проблема с сетью',
    };
    return map[code] || 'Ошибка: ' + code;
}

function validateRegStep1() {
    const n = document.getElementById('regNick').value.trim();
    const u = document.getElementById('regUser').value.trim().replace('@','');
    const ph = document.getElementById('regPhone').value.trim();
    const e = document.getElementById('regEmail').value.trim();
    const p = document.getElementById('regPass').value;
    if(!n) return showToast("Никнейм обязателен");
    if(!e) return showToast("Email обязателен");
    if(p.length < 6) return showToast("Пароль минимум 6 символов");
    S.tempRegData = { nick: n, user: u, phone: ph, email: e, pass: p, avatar: '' };
    showModal('registerModal2');
}

function previewRegAvatar(e) {
    const f = e.target.files[0]; if(!f) return;
    if(f.size > 3*1024*1024) return showToast("Файл больше 3 МБ!");
    const r = new FileReader();
    r.onload = ev => {
        S.tempRegData.avatar = ev.target.result;
        document.getElementById('regAvatarPreview').src = ev.target.result;
        document.getElementById('regAvatarPreview').style.display = 'block';
        document.getElementById('regAvatarIcon').style.display = 'none';
    };
    r.readAsDataURL(f);
}

async function finalizeRegistration() {
    const d = S.tempRegData;
    try {
        const c = await auth.createUserWithEmailAndPassword(d.email, d.pass);
        const p = {
            email: d.email, nickname: d.nick, username: d.user, phone: d.phone,
            avatar: d.avatar, bio: '', vis: 'all', msgVis: 'all',
            online: true, lastSeen: Date.now(), banned: false, joinedAt: Date.now()
        };
        await db.ref('users/' + c.user.uid).set(p);
        S.profile = p;
        showModal('welcomeTestModal');
    } catch(err) {
        showToast(friendlyAuthError(err.code));
    }
}

function startAppAfterReg() { hideModals(); initCoreData(); }

async function doLogout() {
    if(await customConfirm("Выход", "Вы уверены, что хотите выйти из аккаунта?")) {
        if(S.user) await db.ref('users/' + S.user.uid).update({ online: false, lastSeen: Date.now() });
        auth.signOut();
    }
}

