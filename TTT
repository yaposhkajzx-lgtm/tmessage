// =====================================================
// UTILS
// =====================================================
function escapeHtml(s) {
    if(typeof s !== 'string') return '';
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

function escapeAttr(s) {
    if(typeof s !== 'string') return '';
    return s.replace(/&/g,'&amp;').replace(/"/g,'&quot;').slice(0, 100);
}

function formatTime(ts) {
    const dt = new Date(ts), now = new Date();
    const diff = now - dt;
    if(diff < 86400000 && dt.getDate() === now.getDate())
        return dt.toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit' });
    if(diff < 7 * 86400000)
        return dt.toLocaleDateString('ru-RU', { weekday: 'short' });
    return dt.toLocaleDateString('ru-RU', { day: '2-digit', month: '2-digit' });
}

function formatLastSeen(ts) {
    const diff = Date.now() - ts;
    if(diff < 60000) return 'только что';
    if(diff < 3600000) return `${Math.floor(diff/60000)} мин. назад`;
    if(diff < 86400000) return `${Math.floor(diff/3600000)} ч. назад`;
    return new Date(ts).toLocaleDateString('ru-RU', { day: 'numeric', month: 'short' });
}

const USER_COLORS = ['#7c3aed','#2563eb','#059669','#d97706','#dc2626','#0891b2','#be185d','#f97316'];
function getUserColor(uid) {
    let h = 0; for(let i = 0; i < uid.length; i++) h = (h * 31 + uid.charCodeAt(i)) % USER_COLORS.length;
    return USER_COLORS[Math.abs(h) % USER_COLORS.length];
}

