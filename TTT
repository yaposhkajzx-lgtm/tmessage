async function editMessage(mid) {
    if(!S.activeChat) return;
    const cid = S.activeChatType === 'private' ? getChatId(S.user.uid, S.activeChat) : S.activeChat;
    const msgPath = S.activeChatType === 'private' ? 'messages' : 'groupMessages';
    const m = (S.messages[cid] || {})[mid];
    if(!m || m.from !== S.user.uid) return;
    const newText = await customPrompt('Редактировать сообщение', m.text || '');
