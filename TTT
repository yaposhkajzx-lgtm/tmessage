function openChat(id, type) {
    S.activeChat = id;
    S.activeChatType = type;

    document.getElementById('chatEmptyState').style.display = 'none';
    const area = document.getElementById('activeChatArea');
    area.style.display = 'flex';
    if(window.innerWidth <= 768) document.getElementById('app').classList.add('chat-open');

    // (#13) blocked by this user — no chat access at all
    const inputArea = document.getElementById('inputArea');
    if(type === 'private' && S.allContacts?.[id]?.[S.user.uid]?.blocked) {
        updateActiveChatHeader();
        document.getElementById('messagesArea').innerHTML =
            '<div style="text-align:center;color:var(--danger);padding:50px 20px;font-size:14px;">🚫 Пользователь заблокировал(-а) вас.<br>Вы не можете просматривать переписку и писать.</div>';
        inputArea.style.display = 'none';
        renderChatsList();
        return;
    }
    inputArea.style.display = '';

    updateActiveChatHeader();
    renderMessages();
    markAsRead(id, type);
    renderChatsList();
    document.getElementById('messageInput').focus();
}

function closeChat() {
    S.activeChat = null; S.activeChatType = null;
    document.getElementById('app').classList.remove('chat-open');
    document.getElementById('activeChatArea').style.display = 'none';
    document.getElementById('chatEmptyState').style.display = 'flex';
    cancelQuote(); cancelImage();
    debouncedRenderChats();
}

function updateActiveChatHeader() {
    if(!S.activeChat) return;
    const nameEl = document.getElementById('activeChatName');
    const statEl = document.getElementById('activeChatStatus');
    const avEl = document.getElementById('activeChatAvatar');

    if(S.activeChatType === 'private') {
        const u = S.users[S.activeChat]; if(!u) return;
        const cn = u.nickname;
        nameEl.textContent = cn;
        if(u.online) {
            statEl.textContent = 'в сети'; statEl.className = 'cwh-status';
        } else {
            const ls = u.lastSeen ? formatLastSeen(u.lastSeen) : 'давно';
            statEl.textContent = ls; statEl.className = 'cwh-status offline';
        }
        avEl.innerHTML = u.avatar ? `<img src="${u.avatar}" alt="">` : escapeHtml(cn[0].toUpperCase());
    } else {
        const g = S.groups[S.activeChat]; if(!g) return;
        nameEl.textContent = g.name;
        statEl.textContent = (g.members?.length || 0) + ' участников';
        statEl.className = 'cwh-status offline';
        avEl.innerHTML = g.avatar ? `<img src="${g.avatar}" alt="">` : '👥';
    }
}

async function markAsRead(id, type) {
    if(type === 'private') {
        const cid = getChatId(S.user.uid, id);
        const msgs = S.messages[cid]; if(!msgs) return;
        const upd = {};
        Object.keys(msgs).forEach(mid => {
            if(msgs[mid].from !== S.user.uid && !msgs[mid].read) upd[`${cid}/${mid}/read`] = true;
        });
        if(Object.keys(upd).length) {
            await db.ref('messages').update(upd);
        }
    } else if(type === 'group') {
        const readKey = `groupRead_${id}_${S.user.uid}`;
        localStorage.setItem(readKey, Date.now().toString());
        // shared read receipt for group read checkmarks
        db.ref(`groupReads/${id}/${S.user.uid}`).set(firebase.database.ServerValue.TIMESTAMP);
        updateNavBadge();
        debouncedRenderChats();
    }
}

function renderMessages() {
    const container = document.getElementById('messagesArea');
    if(!S.activeChat) return;

    const cid = S.activeChatType === 'private'
        ? getChatId(S.user.uid, S.activeChat)
        : S.activeChat;

    const rawMsgs = Object.entries(S.messages[cid] || {}).sort((a,b) => a[1].time - b[1].time);

    if(!rawMsgs.length) {
        container.innerHTML = `<div style="text-align:center; color:var(--text-muted); padding:40px; font-size:13px;">Нет сообщений. Начните переписку!</div>`;
        return;
    }

    const prevScroll = container.scrollTop;
    const atBottom = container.scrollHeight - container.clientHeight - prevScroll < 60;

    let html = '';
    let lastDate = '';
    let lastFrom = null;

    rawMsgs.forEach(([mid, m], idx) => {
        const dt = new Date(m.time || Date.now());
        const dStr = dt.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' });

        if(dStr !== lastDate) {
            html += `<div class="date-divider"><span>${dStr}</span></div>`;
            lastDate = dStr;
        }

        // system / activity message
        if(m.system) {
            html += `<div class="sys-msg"><span>${escapeHtml(m.text || '')}</span></div>`;
            lastFrom = null;
            return;
        }

        const isSent = m.from === S.user.uid;
        const u = S.users[m.from];
        const timeStr = dt.toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit' });

        const nextMsg = rawMsgs[idx + 1]?.[1];
        const isTail = !nextMsg || nextMsg.from !== m.from || (nextMsg.time - m.time > 60000);
        const sameAsPrev = lastFrom === m.from;

        let quotePart = '';
        if(m.quote) {
            const qSender = m.quote.from === S.user.uid ? 'Вы' : (S.users[m.quote.from]?.nickname || 'Пользователь');
            quotePart = `<div class="msg-quote" onclick="scrollToMsg('${m.quote.id}')">
                <b>${escapeHtml(qSender)}</b><br>${escapeHtml(m.quote.text || '📷 Фото')}
            </div>`;
        }

        let imgPart = m.image ? `<img src="${m.image}" class="msg-img" onclick="openLightbox('${m.image}')" alt="Фото">` : '';
        let textPart = m.text ? `<div class="msg-text">${escapeHtml(m.text).replace(/\n/g,'<br>')}</div>` : '';

        // Reactions
        let reactionsPart = '';
        if(m.reactions) {
            const counts = {};
            Object.values(m.reactions).forEach(emo => { counts[emo] = (counts[emo] || 0) + 1; });
            const mine = m.reactions[S.user.uid];
            const pills = Object.entries(counts).map(([emo, cnt]) =>
                `<span class="reaction-pill ${mine === emo ? 'mine' : ''}" onclick="event.stopPropagation(); toggleReaction('${mid}','${emo}')">${emo}<span class="rc-count">${cnt}</span></span>`
            ).join('');
            if(pills) reactionsPart = `<div class="msg-reactions">${pills}</div>`;
        }
        const editedPart = m.edited ? '<span class="msg-edited">изм.</span>' : '';

        let checkMark = '';
        if(isSent && S.activeChatType === 'private') {
            checkMark = m.read
                ? '<span class="msg-check read">✓✓</span>'
                : '<span class="msg-check">✓</span>';
        } else if(isSent && S.activeChatType === 'group') {
            const reads = S.groupReads?.[S.activeChat] || {};
            const readByOther = Object.entries(reads).some(([uid, ts]) => uid !== S.user.uid && ts >= (m.time || 0));
            checkMark = readByOther
                ? '<span class="msg-check read">✓✓</span>'
                : '<span class="msg-check">✓</span>';
        }

        let authorLine = '';
        if(!isSent && S.activeChatType === 'group' && !sameAsPrev) {
            const color = getUserColor(m.from);
            authorLine = `<div class="msg-author" style="color:${color}" onclick="openPlayerProfile('${m.from}')">${escapeHtml(u?.nickname || '?')}</div>`;
        }

        const avHtml = u?.avatar
            ? `<img src="${u.avatar}" alt="">`
            : escapeHtml((u?.nickname || '?')[0].toUpperCase());

        const showAv = isTail;

        // Safe text for context menu (escaped for JS string)
        const safeText = (m.text || '').replace(/\\/g,'\\\\').replace(/'/g,"\\'").replace(/\n/g,' ').slice(0,100);

        html += `
        <div class="msg-row ${isSent ? 'sent' : 'recv'} ${isTail ? 'tail' : ''}" data-mid="${mid}" data-from="${m.from}" data-text="${escapeAttr(m.text||'')}" data-img="${m.image ? '1' : ''}">
            <div class="msg-side-avatar ${showAv ? '' : 'hidden'}" onclick="${isSent ? "nav('profile')" : `openPlayerProfile('${m.from}')`}">${avHtml}</div>
            <div class="msg-bubble" data-mid="${mid}">
                ${authorLine}
                ${quotePart}
                ${imgPart}
                ${textPart}
                <div class="msg-footer">
                    <span class="msg-time">${timeStr}${editedPart}</span>
                    ${checkMark}
                </div>
                ${reactionsPart}
                <div class="react-btn" data-mid="${mid}">😊</div>
            </div>
            <div class="msg-reply-trigger" data-mid="${mid}">↩</div>
        </div>`;

        lastFrom = m.from;
    });

    container.innerHTML = html;
    if(atBottom) container.scrollTop = container.scrollHeight;

    // Attach event listeners after render (fixes group reply issue)
    container.querySelectorAll('.msg-row').forEach(row => {
        const mid = row.dataset.mid;
        const cid2 = S.activeChatType === 'private' ? getChatId(S.user.uid, S.activeChat) : S.activeChat;
        const m = (S.messages[cid2] || {})[mid];

        // Right-click context menu
        const bubble = row.querySelector('.msg-bubble');
        if(bubble && m) {
            bubble.addEventListener('contextmenu', e => {
                e.preventDefault();
                msgCtxMenu(e, mid, m.text || '', m.from);
            });
        }

        // Reply trigger button
        const replyBtn = row.querySelector('.msg-reply-trigger');
        if(replyBtn && m) {
            replyBtn.addEventListener('click', e => {
                e.stopPropagation();
                prepareQuote(mid, m.text || (m.image ? '📷 Фото' : ''), m.from);
            });
        }

        // React button -> opens emoji popup
        const reactBtn = row.querySelector('.react-btn');
        if(reactBtn && m) {
            reactBtn.addEventListener('click', e => {
                e.stopPropagation();
                openReactPopup(e, mid);
            });
        }

        // Long-press to react (mobile)
        let lpTimer = null;
        const bubbleEl = row.querySelector('.msg-bubble');
        if(bubbleEl && m) {
            bubbleEl.addEventListener('touchstart', e => {
                lpTimer = setTimeout(() => {
                    const t = e.touches[0];
                    openReactPopup({ clientX: t.clientX, clientY: t.clientY }, mid);
                }, 500);
            }, { passive: true });
            bubbleEl.addEventListener('touchend', () => clearTimeout(lpTimer));
            bubbleEl.addEventListener('touchmove', () => clearTimeout(lpTimer), { passive: true });
        }

        // Touch swipe to reply
        let sx = 0;
        row.addEventListener('touchstart', e => { sx = e.touches[0].clientX; }, { passive: true });
        row.addEventListener('touchend', e => {
            const dx = e.changedTouches[0].clientX - sx;
            if(m && dx > 50) prepareQuote(mid, m.text || (m.image ? '📷 Фото' : ''), m.from);
        });
    });
}

function msgCtxMenu(e, mid, text, from) {
    const cid = S.activeChatType === 'private' ? getChatId(S.user.uid, S.activeChat) : S.activeChat;
    const msgPath = S.activeChatType === 'private' ? 'messages' : 'groupMessages';
    showCtxMenu(e, [
        { icon:'↩', label:'Ответить', action: () => {
            const m = (S.messages[cid] || {})[mid];
            prepareQuote(mid, (m && (m.text || (m.image ? '📷 Фото' : ''))) || '…', from);
        }},
        { icon:'📋', label:'Копировать текст', action: () => { if(text) navigator.clipboard.writeText(text).then(() => showToast('Скопировано')); } },
        { icon:'😊', label:'Реакция', action: () => openReactPopup(e, mid) },
        'divider',
        ...(from === S.user.uid ? [
            { icon:'✏️', label:'Редактировать', action: () => editMessage(mid) },
            { icon:'🗑', label:'Удалить сообщение', danger: true, action: async () => {
                if(await customConfirm('Удаление', 'Удалить это сообщение?')) {
                    await db.ref(`${msgPath}/${cid}/${mid}`).remove();
                }
            }}
        ] : []),
    ]);
}

// =====================================================
// REACTIONS
// =====================================================
const REACTION_EMOJIS = ['👍','❤️','😂','😮','😢','🔥','🎉','👎'];

function openReactPopup(e, mid) {
    const pop = document.getElementById('reactPopup');
    pop.innerHTML = REACTION_EMOJIS.map(emo =>
        `<div class="rp-emoji" onclick="toggleReaction('${mid}','${emo}'); closeReactPopup()">${emo}</div>`
    ).join('');
    pop.classList.add('open');
    const pw = REACTION_EMOJIS.length * 42 + 16;
    let x = (e.clientX || window.innerWidth / 2) - pw / 2;
    x = Math.max(8, Math.min(x, window.innerWidth - pw - 8));
    let y = (e.clientY || 200) - 56;
    if(y < 8) y = (e.clientY || 200) + 16;
    pop.style.left = x + 'px';
    pop.style.top = y + 'px';
}
function closeReactPopup() { document.getElementById('reactPopup').classList.remove('open'); }
document.addEventListener('click', e => {
    if(!e.target.closest('#reactPopup') && !e.target.closest('.react-btn')) closeReactPopup();
});

async function toggleReaction(mid, emoji) {
    if(!S.activeChat) return;
    const cid = S.activeChatType === 'private' ? getChatId(S.user.uid, S.activeChat) : S.activeChat;
    const msgPath = S.activeChatType === 'private' ? 'messages' : 'groupMessages';
    const ref = db.ref(`${msgPath}/${cid}/${mid}/reactions/${S.user.uid}`);
    const cur = (S.messages[cid]?.[mid]?.reactions || {})[S.user.uid];
    if(cur === emoji) {
        await ref.remove();
    } else {
        await ref.set(emoji);
    }
