            display: flex; align-items: center; justify-content: center; font-weight: 700; overflow: hidden; font-size: 15px;
        }
        .notif-row .nr-av img { width: 100%; height: 100%; object-fit: cover; }
        .notif-row .nr-body { flex: 1; min-width: 0; }
        .notif-row .nr-text { font-size: 13px; line-height: 1.4; }
        .notif-row .nr-text b { font-weight: 700; }
        .notif-row .nr-time { font-size: 11px; color: var(--text-muted); margin-top: 2px; }
        .notif-row .nr-btns { display: flex; gap: 5px; flex-shrink: 0; }
        .notif-dot {
            position: absolute; top: 5px; right: 5px; width: 9px; height: 9px; border-radius: 50%;
            background: var(--danger); border: 2px solid var(--bg-nav); display: none;
        }
        .notif-dot.show { display: block; }

        /* Member picker (#1) */
        .member-pick-list { max-height: 320px; overflow-y: auto; }
        .member-pick-row {
            display: flex; align-items: center; gap: 11px; padding: 9px 6px; border-radius: 8px; cursor: pointer; transition: background .12s;
        }
        .member-pick-row:hover { background: var(--bg-hover); }
        .member-pick-row .mp-av {
            width: 38px; height: 38px; border-radius: 50%; background: var(--accent); flex-shrink: 0;
            display: flex; align-items: center; justify-content: center; font-weight: 700; overflow: hidden; font-size: 14px;
        }
        .member-pick-row .mp-av img { width: 100%; height: 100%; object-fit: cover; }
        .member-pick-row .mp-info { flex: 1; min-width: 0; }
        .member-pick-row .mp-check {
            width: 22px; height: 22px; border-radius: 6px; border: 2px solid var(--border); flex-shrink: 0;
            display: flex; align-items: center; justify-content: center; font-size: 14px; color: #fff;
        }
        .member-pick-row.checked .mp-check { background: var(--accent); border-color: var(--accent); }

        .friend-state-btn { font-size: 13px; padding: 8px 16px; border-radius: 9px; border: none; cursor: pointer; font-weight: 600; transition: .15s; }
        .fsb-add { background: var(--accent); color: #fff; }
        .fsb-pending { background: var(--bg-input); color: var(--text-muted); cursor: default; }
        .fsb-accept { background: var(--online); color: #fff; }
        .fsb-friends { background: var(--bg-input); color: var(--text-main); }

        @media (max-width: 768px) {
            :root { --nav-width: 260px; }
            .side-nav { position: absolute; left: -110%; top: var(--top-height); bottom: 0; z-index: 90; transition: left .3s; width: 250px; border-right: none; }
            .side-nav.open { left: 0; box-shadow: 10px 0 30px rgba(0,0,0,.5); }
            .mobile-menu-btn { display: block; margin-right: 8px; }
            .logo-area { min-width: auto; }
            .global-search { display: none; }
            .chat-list-panel { width: 100%; position: absolute; inset: 0; z-index: 10; transition: transform .3s; }
            .chat-window { position: absolute; inset: 0; z-index: 20; transform: translateX(100%); transition: transform .3s; }
            .app-container.chat-open .chat-list-panel { transform: translateX(-100%); }
            .app-container.chat-open .chat-window { transform: translateX(0); }
            .mobile-back-btn { display: block; }
            .msg-bubble { max-width: 82%; }
            #profileScreen { padding: 0; }
            .profile-card { border-radius: 0; border: none; }
            #friendsScreen { padding: 14px; }
            #settingsScreen { padding: 14px; }
            .modal-box { padding: 20px; }
            .theme-grid { grid-template-columns: repeat(2, 1fr); }
            .notif-panel { width: 100%; max-width: 100%; }
            #playerProfileScreen { padding: 12px; }
            .post-composer, .post-card, .pp-tab-content, .pp-tabs, .pp-back { max-width: 100%; }
            .chat-input-bar { padding-bottom: calc(10px + env(safe-area-inset-bottom)); }
            .top-bar { padding-top: env(safe-area-inset-top); height: calc(var(--top-height) + env(safe-area-inset-top)); }
            .friends-tab { padding: 9px 12px; font-size: 13px; }
            .post-stats-bar { gap: 14px; }
            .react-btn { opacity: 1; }
        }
    </style>
</head>
