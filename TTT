// =====================================================
// FRIEND REQUEST SYSTEM (#10)
// =====================================================
// returns array of uids that are mutual, non-blocked, existing friends of `ownerUid`
function mutualFriendsOf(ownerUid) {
    const theirs = S.allContacts?.[ownerUid] || {};
    return Object.keys(theirs).filter(fid => {
        if(fid === ownerUid) return false;
        if(!S.users[fid]) return false;                 // must exist
        if(theirs[fid]?.blocked) return false;          // not blocked by owner
        const back = S.allContacts?.[fid]?.[ownerUid];  // must be mutual
        if(!back || back.blocked) return false;
        return true;
    });
}

function getFriendState(uid) {
    if(uid === S.user.uid) return 'self';
    if(S.contacts[uid]?.blocked) return 'blocked';
    if(S.contacts[uid]) return 'friends';
    if(S.incomingReq[uid]) return 'incoming';   // they sent me a request
    if(S.outgoingReq[uid]) return 'outgoing';   // I sent them a request
    return 'none';
}

async function sendFriendRequest(uid) {
    const u = S.users[uid];
    if(!u) return;
    // privacy: respect msgVis 'nobody'
    if(u.msgVis === 'nobody') return showToast('Этот игрок ограничил добавление');
    const state = getFriendState(uid);
    if(state === 'friends') return showToast('Уже в друзьях');
    if(state === 'outgoing') return showToast('Заявка уже отправлена');
    if(state === 'incoming') return acceptFriendRequest(uid); // they already asked -> accept
    await db.ref(`friendRequests/${uid}/${S.user.uid}`).set(firebase.database.ServerValue.TIMESTAMP);
    await pushNotification(uid, { type: 'friend_request' });
    showToast(`📨 Заявка отправлена ${u.nickname}`);
    refreshPlayerProfileIfOpen();
}

async function acceptFriendRequest(fromUid) {
    const u = S.users[fromUid];
    const myName = u?.nickname || fromUid;
    // create mutual friendship
    const updates = {};
    updates[`contacts/${S.user.uid}/${fromUid}`] = { customName: u?.nickname || fromUid, blocked: false, pinned: false };
    updates[`contacts/${fromUid}/${S.user.uid}`] = { customName: S.profile?.nickname || S.user.uid, blocked: false, pinned: false };
    updates[`friendRequests/${S.user.uid}/${fromUid}`] = null;
    updates[`friendRequests/${fromUid}/${S.user.uid}`] = null;
    await db.ref().update(updates);
    await pushNotification(fromUid, { type: 'friend_accept' });
    showToast(`✅ Вы и ${myName} теперь друзья`);
    refreshPlayerProfileIfOpen();
}

async function declineFriendRequest(fromUid) {
    await db.ref(`friendRequests/${S.user.uid}/${fromUid}`).remove();
    showToast('Заявка отклонена');
}

async function cancelOutgoingRequest(toUid) {
